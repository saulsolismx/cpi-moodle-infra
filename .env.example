# --- Dominio del campus (subdominio dedicado; NO uses el dominio raiz) -------
MOODLE_DOMAIN=campus.cpivirtual.com
MOODLE_WWWROOT=https://campus.cpivirtual.com
ACME_EMAIL=tucorreo@cpivirtual.com

# --- Base de datos (usa contrasenas largas y aleatorias) ---------------------
DB_NAME=moodle
DB_USER=moodle
DB_PASSWORD=CAMBIA_ESTO_password_db_larga
DB_ROOT_PASSWORD=CAMBIA_ESTO_password_root_larga

# --- Cuenta admin de Moodle (se usa en el instalador CLI) --------------------
ADMIN_PASSWORD=CAMBIA_ESTO_Admin123!segura
ADMIN_EMAIL=admin@cpivirtual.com
